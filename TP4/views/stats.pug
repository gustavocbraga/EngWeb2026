extends layout 

block content 
  .w3-card-4
    header.w3-container.w3-teal
      h1 Estatísticas
    
    .w3-container
      header.w3-container.w3-margin-top
        h3 Gênero
      table.w3-table-all.w3-margin-top
        tr
          th Masculino
          th Feminino
        tr
          td= stats.genero.M || 0
          td= stats.genero.F || 0

    .w3-container
      header.w3-container.w3-margin-top
        h3 Clubes
      table.w3-table-all.w3-margin-top
        tr
          th Clube
          th Número de atletas
        each contagem, clube in stats.clube 
          tr
            td= clube
            td= contagem
    
    .w3-container
      header.w3-container.w3-margin-top
        h3 Atletas federados
      table.w3-table-all.w3-margin-top
        tr
          th Federado
          th Não federado
        tr
          td= stats.federado.sim || 0
          td= stats.federado.nao || 0
    
    .w3-container
      header.w3-container.w3-margin-top
        h3 Resultados
      table.w3-table-all.w3-margin-top
        tr
          th Apto
          th Não Apto
        tr
          td= stats.resultado.apto || 0
          td= stats.resultado.naoApto || 0
    .w3-container.w3-padding-16
      a.w3-btn.w3-round.w3-grey.w3-small.w3-margin-left(href="/") Voltar
    