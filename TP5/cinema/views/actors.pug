extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Lista de Atores e Participações
    
    .w3-container
      table.w3-table-all.w3-margin-top.w3-margin-bottom
        tr
          th Nome do Ator
          th Número de Filmes
        each a in atores
          tr
            td
              a(href=`/atores/${a.id}`)= a.actor
            td
              span= contagem[a.id] ? contagem[a.id] : 0