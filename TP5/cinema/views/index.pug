extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 Filmes 

    .w3-container 
      table.w3-table-all.w3-margin-top 
        tr  
          th ID
          th Título 
          th Ano 
          th #Generos 
          th #Atores 
        each film in list
          tr
            td 
              a(href=`/filmes/${film.id}`)= film.id
            td=film.title
            td=film.year 
            td= film.genres ? film.genres.length : 0
            td= film.cast ? film.cast.length : 0



