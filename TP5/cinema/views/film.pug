extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1=`Filme: ${filme.title}`
    
    .w3-container
      ul.w3-ul.w3-margin-top  
        li 
          b Ano: 
          span= filme.year  
        li 
          b Generos: 
          span= filme.genres ? filme.genres.join(', ') : 'N/A'
        li 
          b Atores: 
          each ator,index  in filme.cast   
            a(href=`/atores/${ator.id}`)= ` ${ator.actor}`
            if index < filme.cast.length - 1
                span ,
            
        